templ previewDaisyAlert() {
	@previewSection("Variants") {
		<div class="flex flex-col gap-3 w-full">
			@daisyui.Alert(daisyui.AlertProps{Variant: daisyui.AlertInfo}) {
				<span>Informational alert from DaisyUI.</span>
			}
			@daisyui.Alert(daisyui.AlertProps{Variant: daisyui.AlertSuccess}) {
				<span>Action completed successfully.</span>
			}
			@daisyui.Alert(daisyui.AlertProps{Variant: daisyui.AlertWarning}) {
				<span>Please review before proceeding.</span>
			}
			@daisyui.Alert(daisyui.AlertProps{Variant: daisyui.AlertError}) {
				<span>Something went wrong. Try again.</span>
			}
		</div>
	}
}

templ previewDaisyCard() {
	@previewSection("Card") {
		<div class="w-full max-w-sm">
			@daisyui.Card(daisyui.CardProps{Bordered: true}) {
				@daisyui.CardBody() {
					@daisyui.CardTitle() { DaisyUI Card }
					<p class="text-sm">A themed card component using DaisyUI v5 classes and CSS variables.</p>
					@daisyui.CardActions() {
						@daisyui.Button(daisyui.ButtonProps{Variant: daisyui.ButtonPrimary}) { Buy Now }
					}
				}
			}
		</div>
	}
	@previewSection("Compact Card") {
		<div class="w-full max-w-sm">
			@daisyui.Card(daisyui.CardProps{Bordered: true, Compact: true}) {
				@daisyui.CardBody() {
					@daisyui.CardTitle() { Compact Card }
					<p class="text-sm">Less padding, same style.</p>
				}
			}
		</div>
	}
}

templ previewDaisyInput() {
	@previewSection("Input Variants") {
		<div class="flex flex-col gap-4 w-full max-w-sm">
			@daisyui.Input(daisyui.InputProps{
				Placeholder: "Default input",
			})
			@daisyui.Input(daisyui.InputProps{
				Variant:     daisyui.InputPrimary,
				Placeholder: "Primary",
			})
			@daisyui.Input(daisyui.InputProps{
				Variant:     daisyui.InputSuccess,
				Placeholder: "Success",
			})
			@daisyui.Input(daisyui.InputProps{
				Variant:     daisyui.InputError,
				Placeholder: "Error state",
			})
			@daisyui.Input(daisyui.InputProps{
				Placeholder: "Disabled input",
				Disabled:    true,
			})
		</div>
	}
}

// ── Shared helper ─────────────────────────────────────────────────────────────

templ previewSection(label string) {
	<div class="w-full">
		<p class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-4">{ label }</p>
		<div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
			{ children... }
		</div>
	</div>
}
